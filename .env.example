# ============================================================
# NeuroGenesis AI Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# NEVER expose non-VITE_ keys to the frontend bundle.
# ============================================================

# --- Groq AI (Primary AI Provider — REQUIRED) ---
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# --- NVIDIA NIM (ESMFold protein structure — Optional) ---
# Get your key at: https://build.nvidia.com
NVIDIA_NIM_API_KEY=""

# --- Clerk Authentication (REQUIRED) ---
# Get keys at: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
CLERK_SECRET_KEY="sk_test_your_secret_key_here"

# --- App ---
NODE_ENV="development"
PORT=3000
VITE_API_BASE_URL="http://localhost:3000"

# --- CORS (production only — comma-separated) ---
# ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# --- External Biomedical APIs (free, no key required) ---
PUBCHEM_BASE_URL="https://pubchem.ncbi.nlm.nih.gov/rest/pug"
UNIPROT_BASE_URL="https://rest.uniprot.org"
CHEMBL_BASE_URL="https://www.ebi.ac.uk/chembl/api/data"
PDB_BASE_URL="https://data.rcsb.org/rest/v1"
CLINICAL_TRIALS_BASE_URL="https://clinicaltrials.gov/api/v2"
